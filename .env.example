WEBEX_BOT_TOKEN=
WEBEX_USER_TOKEN=
WEBEX_CLIENT_ID=
WEBEX_CLIENT_SECRET=
WEBEX_REDIRECT_URI=http://localhost:8765/oauth/callback
WEBEX_OAUTH_SCOPES=spark:all spark:webhooks_read spark:webhooks_write meeting:schedules_read meeting:schedules_write meeting:recordings_read meeting:transcripts_read meeting:summaries_read meeting:controls_read meeting:controls_write meeting:preferences_read meeting:preferences_write
# Optional for Webex Calling CDR tools:
# Add spark:calls_read and spark:xsi for user-level active-call and call-history tools.
# Add spark-admin:calling_cdr_read to WEBEX_OAUTH_SCOPES and make sure the OAuth user has the Control Hub "Webex Calling Detailed Call History API access" role.
# Add spark-admin:locations_read only if you need location metadata and selected that scope in the Webex developer portal.
# Optional overrides. By default, tokens and local state live in your per-user state dir.
# WEBEX_MCP_ENABLE_LOCAL_FILES=false
# WEBEX_MCP_LOCAL_FILE_ROOTS=/absolute/path/one:/absolute/path/two
# WEBEX_OAUTH_TOKEN_FILE=
# WEBEX_MCP_DOWNLOAD_DIR=
# WEBEX_MCP_INDEX_DB=
# WEBEX_CALLING_CDR_BASE_URL=https://analytics-calling.webexapis.com/v1
